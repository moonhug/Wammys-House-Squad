---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFeaturedPosts, getVisibleSortedPosts } from "../utils/posts";

const posts = await getCollection("posts");
const visiblePosts = getVisibleSortedPosts(posts);
const featuredPosts = getFeaturedPosts(posts);
const featuredIds = new Set(featuredPosts.map((post) => post.id));
const latestPosts = visiblePosts
  .filter((post) => !featuredIds.has(post.id))
  .slice(0, 6);
---

<BaseLayout currentPath="/">
  <section class="panel page-intro">
    <h2>Notes on Games, and the Ways We Read Them</h2>
    <p class="page-intro__lead">
      Wammy&apos;s House Squad is a place to keep our notes on games: sometimes from
      the perspective of a technician, sometimes from the heart of a player.
      L and the juniors post in whatever form feels right to them, and within the
      wide world of games, this becomes a shared space for thoughts, experiences,
      and all the things we see, hear, and feel to be expressed freely.
    </p>
    <p class="page-intro__local" lang="ko">
      와미즈 하우스 스쿼드 - Wammy&apos;s House Squad - 는 게임을 좋아하고 탐구하며,
      때로는 기술자의 시선으로, 때로는 게이머의 마음으로 느낀 것들을 기록해 두는 곳입니다.
      엘과 주니어들은 각자가 원하는 방식으로 아티클을 올리고, 게임이라는 큰 범주 안에서
      생각과 경험을 나누며 함께 자라갑니다. 우리가 보고, 듣고, 느낀 것들을
      기술자이자 게이머의 시각으로 자유롭게 풀어내는 자리이기도 합니다.
    </p>
  </section>

  {featuredPosts.length > 0 && (
    <section class="panel">
      <div class="section-heading">
        <h2>Featured Posts</h2>
        <p>Highlighted pieces that show the different writing workflows in this repo.</p>
      </div>
      <div class="article-list">
        {featuredPosts.map((post) => (
          <ArticleCard post={post} />
        ))}
      </div>
    </section>
  )}

  <section class="panel">
    <div class="section-heading">
      <h2>Latest Posts</h2>
      <p>Recent articles from both the tech and game sections.</p>
    </div>
    <div class="article-list">
      {latestPosts.map((post) => (
        <ArticleCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
